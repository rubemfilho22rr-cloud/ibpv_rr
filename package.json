{
  "name": "relatorio-financeiro-ibpv",
  "version": "1.6.0",
  "description": "Relatório Financeiro da Igreja Batista Palavra da Vida",
  "main": "electron-main.js",
  "author": "Igreja Batista Palavra da Vida",
  "license": "UNLICENSED",
  "private": true,
  "scripts": {
    "start": "pnpm run build:web && electron .",
    "dev:web": "vite --configLoader runner --host 127.0.0.1",
    "build": "pnpm run build:web",
    "build:web": "vite build --configLoader runner",
    "test": "node --test tests/*.test.mjs",
    "build:windows": "pnpm run build:web && electron-builder --win nsis portable --x64",
    "pack": "pnpm run build:web && electron-builder --dir --win --x64"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.52.1"
  },
  "devDependencies": {
    "electron": "37.3.1",
    "electron-builder": "26.0.12",
    "vite": "^7.0.5"
  },
  "build": {
    "appId": "br.org.ibpv.relatoriofinanceiro",
    "productName": "Relatório Financeiro IBPV",
    "asar": true,
    "files": [
      "electron-main.js",
      "preload.js",
      "app/assets/logo-ibpv.ico",
      "web-dist/**/*"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "icon": "app/assets/logo-ibpv.ico",
      "signAndEditExecutable": false,
      "target": [
        { "target": "nsis", "arch": ["x64"] },
        { "target": "portable", "arch": ["x64"] }
      ]
    },
    "nsis": {
      "artifactName": "Relatorio Financeiro IBPV DESTRAVADO Setup ${version} ${arch}.${ext}",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Relatório Financeiro IBPV",
      "installerIcon": "app/assets/logo-ibpv.ico",
      "uninstallerIcon": "app/assets/logo-ibpv.ico"
      ,"deleteAppDataOnUninstall": false
    },
    "portable": {
      "artifactName": "Relatorio Financeiro IBPV DESTRAVADO Portable ${version} ${arch}.${ext}"
    }
  }
}
